# ─────────────────────────────────────────────────────────────
# Dijital Gardrop Backend — Ortam Değişkenleri
#
# Kullanım:
#   cp .env.example .env
#   .env dosyasını kendi değerlerinizle düzenleyin
# ─────────────────────────────────────────────────────────────

# Sunucu — Fiziksel cihazdan erişim için Mac/PC'nin yerel IP'si yazılır
# Mac'te bulmak için: ipconfig getifaddr en0
# Windows'ta: ipconfig | findstr IPv4
SERVER_HOST=localhost
SERVER_PORT=8000

# Veritabanı — Proje kökünde otomatik oluşur, değiştirmeye gerek yok
# DATABASE_PATH=./dijital_gardrop.db

# AI Servisleri (isteğe bağlı)
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.5-flash

# CORS — Flutter uygulamasının çalıştığı origin'leri buraya ekleyin
# CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://10.5.5.11:8081
